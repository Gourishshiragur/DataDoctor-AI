# Copy this file to .streamlit/secrets.toml and fill in your key to enable
# live AI code suggestions. Without it, the AI Assistant page falls back to
# a local template library automatically — the app works either way.
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional Databricks Free Edition backend
DATABRICKS_HOST = "https://dbc-3546ff4a-f6e5.cloud.databricks.com"
DATABRICKS_TOKEN = ""
DATABRICKS_CATALOG = "workspace"
DATABRICKS_SCHEMA = "datadoctor"
DATABRICKS_VOLUME = "source_files"
DATABRICKS_USER = ""
DATABRICKS_RUN_TIMEOUT_SECONDS = "900"
